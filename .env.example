# Database (leave empty for SQLite)
DATABASE_URL=postgres://user:password@host:5432/dbname
# or: mysql://user:password@host:3306/dbname
# or: sqlite:////data/db.sqlite (default)

# Coolify DB override (optional)
# If set, this takes priority over auto-detection / saved config.
# Example: postgresql://coolify:password@coolify-db:5432/coolify
COOLIFY_DB_URL=

# Docker socket path (optional)
DOCKER_SOCKET=/var/run/docker.sock

# SQLite only (if DATABASE_URL is empty)
# DB_PATH=/data/db.sqlite

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Server
HOST=0.0.0.0
PORT=8080

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=60
RATE_LIMIT_ADMIN_LOGIN_PER_MINUTE=20
RATE_LIMIT_ADMIN_LOGIN_BURST=10
TRUST_PROXY_HEADERS=true

# ── Coolify HTTP API (admin write actions: redeploy, cancel) ──────────
# When the gateway runs on the same host as Coolify (recommended), point
# this at the internal Docker network address — bypasses TLS, reverse
# proxy, and any external WAF.
#
# Internal (preferred):  http://coolify:8000
# External:              https://coolify.your-host.example
#
# The gateway must be on Coolify's docker network — see docker-compose.yml
# networks section for the `coolify: external: true` config.
COOLIFY_API_URL=http://coolify:8000
COOLIFY_API_TOKEN=
